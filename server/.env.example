# Server
PORT="3001"
CORS_ORIGIN="http://localhost:3000"
APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# Gemini API key used only by the backend.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Admin project config.
FIREBASE_PROJECT_ID="MY_PROJECT_ID"
FIREBASE_FIRESTORE_DATABASE_ID="(default)"
FIREBASE_STORAGE_BUCKET="MY_PROJECT.appspot.com"

# Set true in production if original uploaded files must be archived in Storage.
REQUIRE_FIREBASE_STORAGE="false"

# Absolute or server-relative path to your Firebase service account JSON key file.
# Example: ./firebase-key.json
# Leave empty in managed Google Cloud runtimes that use Application Default Credentials.
FIREBASE_SERVICE_ACCOUNT_PATH=""

# Optional API rate limits for report endpoints.
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="120"
