# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CORS_ORIGIN: Comma-separated list of frontend origins allowed to call the backend.
# For local Vite development, use http://localhost:3000.
CORS_ORIGIN="http://localhost:3000"

# VITE_API_BASE_URL: Browser-facing API base URL.
VITE_API_BASE_URL="http://localhost:3001/api"

# Firebase web app config used by the browser for Firebase Auth.
VITE_FIREBASE_API_KEY="MY_FIREBASE_WEB_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="MY_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="MY_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="MY_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="MY_SENDER_ID"
VITE_FIREBASE_APP_ID="MY_FIREBASE_WEB_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID=""

# Backend Firebase project config. Keep real values in local .env or deployment secrets.
FIREBASE_PROJECT_ID="MY_PROJECT_ID"
FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# Optional backend Storage bucket override.
# Use this if Firebase Console shows a different bucket than the web app config.
FIREBASE_STORAGE_BUCKET="MY_PROJECT.appspot.com"

# Set true in production if original uploaded files must be archived in Storage.
# When false, the app still saves analysis if Firebase Storage is not enabled.
REQUIRE_FIREBASE_STORAGE="false"

# FIREBASE_SERVICE_ACCOUNT_PATH: Absolute path to your Firebase service account JSON key file.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Example: /Users/you/keys/firebase-service-account.json
# If running on GCP (Cloud Run, etc.) this can be left empty — Application Default Credentials are used.
FIREBASE_SERVICE_ACCOUNT_PATH=""

# Optional API rate limits for report endpoints.
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX="120"
